UINT MX_USBX_Device_CDC_Init(VOID *memory_ptr)
{
	  UINT ret = UX_SUCCESS;

	  /* Get Device Framework High Speed and get the length */
	  device_framework_high_speed = (UCHAR *) CDC_device_frameword_high_speed;
	  device_framework_hs_length = sizeof(CDC_device_frameword_high_speed);
	  /* Get Device Framework Full Speed and get the length */
	  device_framework_full_speed =(UCHAR *)CDC_device_frameword_full_speed;
	  device_framework_fs_length = sizeof(CDC_device_frameword_full_speed);
	  /* Get String Framework and get the length */
	  string_framework = USBD_Get_String_Framework(&string_framework_length);

	   				  				  /* Get Language Id Framework and get the length */
	   			language_id_framework = USBD_Get_Language_Id_Framework(&language_id_framework_length);

	  TX_BYTE_POOL *byte_pool = (TX_BYTE_POOL*)memory_ptr;

	  /* USER CODE BEGIN MX_USBX_Device_Init0 */

	  /* USER CODE END MX_USBX_Device_Init0 */
	  /* Allocate the stack for USBX Memory */
	  if (tx_byte_allocate(byte_pool, (VOID **) &CDCpointer,
	                       USBX_DEVICE_MEMORY_STACK_SIZE, TX_NO_WAIT) != TX_SUCCESS)
	  {
	    /* USER CODE BEGIN USBX_ALLOCATE_STACK_ERROR */
	    return TX_POOL_ERROR;
	    /* USER CODE END USBX_ALLOCATE_STACK_ERROR */
	  }
	  /* Initialize USBX Memory */
	  if (ux_system_initialize(CDCpointer, USBX_DEVICE_MEMORY_STACK_SIZE, UX_NULL, 0) != UX_SUCCESS)
	  {
	    /* USER CODE BEGIN USBX_SYSTEM_INITIALIZE_ERROR */
	    return UX_ERROR;
	    /* USER CODE END USBX_SYSTEM_INITIALIZE_ERROR */
	  }

	  /* Install the device portion of USBX */
	  if (ux_device_stack_initialize((UCHAR*)device_framework_high_speed,
			  device_framework_hs_length,
			  (UCHAR*)device_framework_full_speed,
	                                 device_framework_fs_length,
	                                 string_framework,
	                                 string_framework_length,
	                                 language_id_framework,
	                                 language_id_framework_length,
	                                 UX_NULL) != UX_SUCCESS)
	  {
	    /* USER CODE BEGIN USBX_DEVICE_INITIALIZE_ERROR */
	    return UX_ERROR;
	    /* USER CODE END USBX_DEVICE_INITIALIZE_ERROR */
	  }

	  /* Initialize the cdc acm class parameters for the device */
	  cdc_acm_parameter.ux_slave_class_cdc_acm_instance_activate   = USBD_CDC_ACM_Activate;
	  cdc_acm_parameter.ux_slave_class_cdc_acm_instance_deactivate = USBD_CDC_ACM_Deactivate;
	  cdc_acm_parameter.ux_slave_class_cdc_acm_parameter_change    = USBD_CDC_ACM_ParameterChange;

	  /* USER CODE BEGIN CDC_ACM_PARAMETER */

	  /* USER CODE END CDC_ACM_PARAMETER */

	  /* Get cdc acm configuration number */
	  cdc_acm_configuration_number = USBD_Get_Configuration_Number(CLASS_TYPE_CDC_ACM, 0);

	  /* Find cdc acm interface number */
	  cdc_acm_interface_number = USBD_Get_Interface_Number(CLASS_TYPE_CDC_ACM, 0);

	  /* Initialize the device cdc acm class */
	  if (ux_device_stack_class_register(_ux_system_slave_class_cdc_acm_name,
	                                     ux_device_class_cdc_acm_entry,
	                                     cdc_acm_configuration_number,
	                                     cdc_acm_interface_number,
	                                     &cdc_acm_parameter) != UX_SUCCESS)
	  {
	    /* USER CODE BEGIN USBX_DEVICE_CDC_ACM_REGISTER_ERROR */
	    return UX_ERROR;
	    /* USER CODE END USBX_DEVICE_CDC_ACM_REGISTER_ERROR */
	  }

	  /* USER CODE BEGIN MX_USBX_Device_Init1 */
	   USBX_APP_Device_Init();
	   HAL_PCD_Start(&hpcd_USB_OTG_HS);
    /* Allocate memory for the UX RX thread */
     /* Allocate memory for the UX TX thread */

    /* USER CODE END MX_USBX_Device_Init1 */
    return ret;
  }

#define USB_AHB_IDLE_TIMEOUT_MS    200
#define USB_CSRST_TIMEOUT_MS       200
#define USB_FIFO_FLUSH_TIMEOUT_MS  100
#define USB_RECOVER_DELAY_MS       5

UINT USBX_MSC_Device_Deint(VOID)
{
	uint8_t t=0;
	UINT status = UX_SUCCESS;
	HAL_NVIC_DisableIRQ(OTG_HS_IRQn);
	//Soft disconnect device
	USB_OTG_GlobalTypeDef *USBx = hpcd_USB_OTG_HS.Instance;
	  uint32_t USBx_BASE = (uint32_t)USBx;
	USBx_DEVICE->DCTL |= USB_OTG_DCTL_SDIS;
	HAL_Delay(10);
	HAL_PCD_Stop(&hpcd_USB_OTG_HS);

	 status = ux_device_stack_class_unregister(_ux_system_slave_class_storage_name,ux_device_class_storage_entry);
	     if (status != UX_SUCCESS)
	     {
	         /* USER CODE BEGIN USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
	         return UX_ERROR;
	         /* USER CODE END USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
	     }
	     status =  ux_device_stack_uninitialize();
	     if (status != UX_SUCCESS)
		 {
			 /* USER CODE BEGIN USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
			 return UX_ERROR;
			 /* USER CODE END USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
		 }
	 //ux_device_stack_interface_delete(_ux_system_slave);
	 ux_system_uninitialize();
	 HAL_PCD_DeInit(&hpcd_USB_OTG_HS);
	 if (status != UX_SUCCESS)
	 {
		 /* USER CODE BEGIN USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
		 return UX_ERROR;
		 /* USER CODE END USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
	 }
	// USB_CoreReset(hpcd_USB_OTG_HS.Instance);
//	 for (uint8_t ep = 0x00; ep < 0x10; ep++)
//	 {
//		 HAL_PCD_EP_Flush(&hpcd_USB_OTG_HS, ep);
//	 }



	 __HAL_RCC_USB_OTG_HS_FORCE_RESET();
	     HAL_Delay(10);  /* or tx_thread_sleep(1) if inside ThreadX context */
	     __HAL_RCC_USB_OTG_HS_RELEASE_RESET();

	     /* 3. Disable and re-enable clock (optional but recommended) */
	 	// Reset OTG core

	     __HAL_RCC_USB_OTG_HS_CLK_DISABLE();
	     __HAL_RCC_USBPHYC_CLK_DISABLE();
	     HAL_Delay(10);
	     __HAL_RCC_USB_OTG_HS_CLK_ENABLE();
	     __HAL_RCC_USBPHYC_CLK_ENABLE();
	     HAL_Delay(10);
	     __HAL_RCC_USB_OTG_HS_CLK_DISABLE();
		 __HAL_RCC_USBPHYC_CLK_DISABLE();
	     // 1. Enable USB clocks (powers PHY)
	     __HAL_RCC_USB_OTG_HS_CLK_ENABLE();
	     __HAL_RCC_USBPHYC_CLK_ENABLE();
	     HAL_Delay(10);

	     // 2. Enable USB PHY power domain
	     HAL_Delay(10);
	     __HAL_RCC_USB_OTG_HS_CLK_ENABLE();
	    	     __HAL_RCC_USBPHYC_CLK_ENABLE();
	    	     HAL_Delay(10);

	   /*  Wait for AHB idle */
//	     if (USBx->GRSTCTL & USB_OTG_GRSTCTL_CSRST) {
//	         /* toggle USB clock & PHY */
//	    	 __HAL_RCC_USB_OTG_HS_CLK_DISABLE();
//	         HAL_Delay(USB_RECOVER_DELAY_MS);
//	         __HAL_RCC_USB_OTG_HS_CLK_ENABLE();
//	         HAL_Delay(USB_RECOVER_DELAY_MS);
//
//	     }
	     uint32_t timeout = 0;
	     /* 1. Disable global interrupts */
	        USBx->GAHBCFG &= ~USB_OTG_GAHBCFG_GINT;

	        /* 4. Flush TX FIFO */
	        USBx->GRSTCTL |= USB_OTG_GRSTCTL_TXFFLSH;
	        while (USBx->GRSTCTL & USB_OTG_GRSTCTL_TXFFLSH) {
	            if (++timeout > 5000) return 1;   // Safety timeout
	        }

	        /* 5. Flush RX FIFO */
	        timeout = 0;
	        USBx->GRSTCTL |= USB_OTG_GRSTCTL_RXFFLSH;
	        while (USBx->GRSTCTL & USB_OTG_GRSTCTL_RXFFLSH) {
	            if (++timeout > 5000) return 1;
	        }

	        /* 6. Wait for AHB idle */
	        timeout = 0;
	        while (!(USBx->GRSTCTL & USB_OTG_GRSTCTL_AHBIDL)) {
	            if (++timeout > 5000) return 1;
	        }

	        /* 7. Apply OTG Core Reset (CSRST) */
	        timeout = 0;
	        USBx->GRSTCTL |= USB_OTG_GRSTCTL_CSRST;
	        while (USBx->GRSTCTL & USB_OTG_GRSTCTL_CSRST) {
	            if (++timeout > 5000) return 1;
	        }
	        HAL_Delay(5);


	     /* 8) Set HOST mode */
	     USBx->GUSBCFG &= ~USB_OTG_GUSBCFG_FDMOD;  // clear force device mode
	     HAL_Delay(20);
	 	HAL_NVIC_EnableIRQ(OTG_HS_IRQn);
	     _ux_dcd_stm32_uninitialize((ULONG)USB_OTG_HS, (ULONG)&hpcd_USB_OTG_HS);
	 if(DMSC_pointer)
	 {
		 tx_byte_release(DMSC_pointer);
		 DMSC_pointer=NULL;
	 }
	 tx_byte_pool_delete(&ux_device_byte_pool);
	 tx_thread_sleep(10);
	 return UX_SUCCESS;
}


UINT USBX_CDC_Device_Deint(VOID)
{
	UINT status = UX_SUCCESS;
	HAL_PCD_Stop(&hpcd_USB_OTG_HS);

	 status = ux_device_stack_class_unregister(_ux_system_slave_class_cdc_acm_name,ux_device_class_cdc_acm_entry);
	 if (status != UX_SUCCESS)
	 {
		 /* USER CODE BEGIN USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
		 return UX_ERROR;
		 /* USER CODE END USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
	 }
	 //ux_device_stack_disconnect();
	 status =  ux_device_stack_uninitialize();
	 if (status != UX_SUCCESS)
	 {
		 /* USER CODE BEGIN USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
		 return UX_ERROR;
		 /* USER CODE END USBX_DEVICE_STORAGE_UNREGISTER_ERROR */
	 }
	 ux_system_uninitialize();
	 HAL_PCD_DeInit(&hpcd_USB_OTG_HS);
	 for (uint8_t ep = 0x00; ep < 0x10; ep++)
	 {
		 HAL_PCD_EP_Flush(&hpcd_USB_OTG_HS, ep);
	 }
	 __HAL_RCC_USB_OTG_HS_FORCE_RESET();
		 HAL_Delay(2);  /* or tx_thread_sleep(1) if inside ThreadX context */
		 __HAL_RCC_USB_OTG_HS_RELEASE_RESET();

		 /* 3. Disable and re-enable clock (optional but recommended) */
		 __HAL_RCC_USB_OTG_HS_CLK_DISABLE();
		 HAL_Delay(1);
		 __HAL_RCC_USB_OTG_HS_CLK_ENABLE();
		 _ux_dcd_stm32_uninitialize((ULONG)USB_OTG_HS, (ULONG)&hpcd_USB_OTG_HS);
	 if(CDCpointer)
	 {
		 tx_byte_release(CDCpointer);
		 CDCpointer=NULL;
	 }
	 tx_byte_pool_delete(&ux_device_byte_pool);
	 tx_thread_sleep(10);
	 return UX_SUCCESS;
}

/* USER CODE END 1 */
