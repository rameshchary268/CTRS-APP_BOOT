 __ALIGN_BEGIN static const UCHAR MSC_device_frameword_full_speed[] __ALIGN_END =
 {
     /* Device Descriptor */
     0x12,                               /* bLength */
     UX_DEVICE_DESCRIPTOR_ITEM,          /* bDescriptorType = DEVICE */  //0x01
     0x00, 0x02,                         /* bcdUSB */
     0x00,                               /* bDeviceClass */
     0x00,                               /* bDeviceSubClass */
     0x00,                               /* bDeviceProtocol */
     0x40,                               /* bMaxPacketSize0 */
     (0x83), (0x04),     /* idVendor */
     (0x40), (0x57),     /* idProduct */      //lo0x40
     0x00, 0x02,                         /* bcdDevice */
     0x01,                               /* Manufacturer */
     0x02,                               /* Product */
     0x03,                               /* Serial */
     0x01,                               /* NumConfigurations */

     /* Configuration Descriptor */
     0x09, UX_CONFIGURATION_DESCRIPTOR_ITEM,                            //0x09, 0x02
     0x20, 0x00,                         /* wTotalLength */
     0x01,                               /* bNumInterfaces */
     0x01,                               /* bConfigurationValue */
     0x00,                               /* iConfiguration */
     0xC0,                               /* bmAttributes */
     50,                                 /* MaxPower */                                       //0x00

     /* Interface Descriptor */
     0x09, UX_INTERFACE_DESCRIPTOR_ITEM,                         //0x09, 0x04
     0x00, 0x00, 0x02,                   /* bNumEndpoints = 2 */
     0x08,                               /* bInterfaceClass = Mass Storage */
     0x06,                               /* bInterfaceSubClass = SCSI Transparent */
     0x50,                               /* bInterfaceProtocol = BOT */
     0x00,

     /* Endpoint Descriptor (Bulk IN) */
     0x07, UX_ENDPOINT_DESCRIPTOR_ITEM,                        //0x07,0x05
     0x81, 0x02, 0x40, 0x00, 0x00,

     /* Endpoint Descriptor (Bulk OUT) */
     0x07, UX_ENDPOINT_DESCRIPTOR_ITEM,                  //0x07,0x05
     0x01, 0x02, 0x40, 0x00, 0x00,                                             //0x02,0x02
 };

