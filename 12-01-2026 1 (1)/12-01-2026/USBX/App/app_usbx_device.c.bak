/* Private function prototypes -----------------------------------------------*/
static VOID app_ux_device_thread_entry(ULONG thread_input);
/* USER CODE BEGIN PFP */

/* USER CODE END PFP */

/**
  * @brief  Application USBX Device Initialization.
  * @param  memory_ptr: memory pointer
  * @retval status
  */

/**
  * @brief  Function implementing app_ux_device_thread_entry.
  * @param  thread_input: User thread input parameter.
  * @retval none
  */

/* USER CODE BEGIN 1 */

VOID app_ux_device_thread_entry(ULONG thread_input)
{
	HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD9, GPIO_PIN_RESET);
	HAL_GPIO_WritePin(GPIOC, GPIO_ODR_OD1, GPIO_PIN_RESET);
//	HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD9, GPIO_PIN_SET);
	//HAL_GPIO_WritePin(GPIOC, GPIO_ODR_OD1, GPIO_PIN_RESET);
//	usb_info.new_mode=USB_HOST;
	while(1)
	{
		switch(usb_info.state)
		{
		case USB_INIT:
			if(usb_info.new_mode==USB_MSC)
			{
				tx_thread_suspend(&ux_cdc_read_thread);
				//tx_thread_suspend(&ux_cdc_write_thread);
				usb_info.mode=USB_MSC;
				memset(ux_device_byt_pool_buffer, 0,sizeof(ux_device_byt_pool_buffer));
				if (tx_byte_pool_create(&ux_device_byte_pool, "Ux memory pool",ux_device_byt_pool_buffer,UX_DEVICE_APP_MEM_POOL_SIZE) != TX_SUCCESS)
				{
					/* USER CODE BEGIN UX_Device_Byte_Pool_Error */
					 tx_byte_pool_delete(&ux_device_byte_pool);
						 tx_thread_sleep(10);
					/* USER CODE END UX_Device_Byte_Pool_Error */
				}
				else
				{
					/* USER CODE BEGIN UX_Device_Byte_Pool_Success */
					/* USER CODE END UX_Device_Byte_Pool_Success */
					if (MX_USBX_MSC_Device_Init((VOID*) &ux_device_byte_pool) != UX_SUCCESS) {
						/* USER CODE BEGIN  MX_USBX_Device_Init_Error */
						while (1)
						{
						}
						/* USER CODE END  MX_USBX_Device_Init_Error */
					}
					else {
						usb_info.state=USB_MSC_START;
					}
					/* USER CODE BEGIN  MX_USBX_Device_Init_Success */

					/* USER CODE END  MX_USBX_Device_Init_Success */
				}

			}
			else if(usb_info.new_mode==USB_CDC)
			{
				usb_info.mode=USB_CDC;
				 memset(ux_device_byt_pool_buffer,0,sizeof(ux_device_byt_pool_buffer));
				if (tx_byte_pool_create(&ux_device_byte_pool, "Ux memory pool", ux_device_byt_pool_buffer, UX_DEVICE_APP_MEM_POOL_SIZE) != TX_SUCCESS)
				  {
					/* USER CODE BEGIN UX_Device_Byte_Pool_Error */
					 tx_byte_pool_delete(&ux_device_byte_pool);
						 tx_thread_sleep(10);
					/* USER CODE END UX_Device_Byte_Pool_Error */
				  }
				  else
				  {
					/* USER CODE BEGIN UX_Device_Byte_Pool_Success */
					/* USER CODE END UX_Device_Byte_Pool_Success */
					if (MX_USBX_Device_CDC_Init((VOID *)&ux_device_byte_pool) != UX_SUCCESS)
					{
					  /* USER CODE BEGIN  MX_USBX_Device_Init_Error */
					  while(1)
					  {
					  }
					  /* USER CODE END  MX_USBX_Device_Init_Error */
					}
					else
					{
						usb_info.state=USB_CDC_DONE;
					}
					//tx_thread_resume(&ux_cdc_write_thread);
					tx_thread_resume(&ux_cdc_read_thread);
					/* USER CODE BEGIN  MX_USBX_Device_Init_Success */

					/* USER CODE END  MX_USBX_Device_Init_Success */
				  }
			}
			else if(usb_info.new_mode==USB_HOST)
			{

				//tx_thread_suspend(&ux_cdc_write_thread);
				tx_thread_suspend(&ux_cdc_read_thread);
				//HAL_GPIO_WritePin(GPIOC, GPIO_ODR_OD1, GPIO_PIN_SET);
				HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD9, GPIO_PIN_SET);
				HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD12, GPIO_PIN_RESET);
				HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD11, GPIO_PIN_RESET);
				//HAL_Delay(50);
				tx_thread_sleep(50);
				if ((MX_USBX_Host_Init()) != UX_SUCCESS)
				{
				  /* USER CODE BEGIN  MX_USBX_Device_Init_Error */
				  while(1)
				  {
				  }
				  /* USER CODE END  MX_USBX_Device_Init_Error */
				}
				else
				{
					usb_info.state=USB_HOST_DONE;
				}
				/* USER CODE BEGIN  MX_USBX_Device_Init_Success */
				usb_info.host_mode=1;
				usb_info.mode=USB_HOST;
				/* USER CODE END  MX_USBX_Device_Init_Success */

			}

			break;

		case USB_DE_INIT:
			if((usb_info.mode == USB_MSC))
			{
				USBX_MSC_Device_Deint();
			}
			else if(usb_info.mode==USB_CDC)
			{
				//tx_thread_suspend(&ux_cdc_write_thread);
				tx_thread_suspend(&ux_cdc_read_thread);
				USBX_CDC_Device_Deint();
			}
			else if(usb_info.mode==USB_HOST)
			{

				MX_USBX_Host_DeInit();
				usb_info.host_mode=0;
				HAL_GPIO_WritePin(GPIOA, GPIO_ODR_OD9, GPIO_PIN_RESET);
				//HAL_GPIO_WritePin(GPIOC, GPIO_ODR_OD1, GPIO_PIN_RESET);
				//UI_info.state=UI_INIT;
			}
			usb_info.state=USB_INIT;
			break;

		case USB_MSC_START:
			if(USB_DETECT())
			{
				if((vp_rt_wr_str.LoginStatus==2)||((login_cred[1].admin_id[0] ==0)||(login_cred[1].admin_id[0] ==255)))
				{
					/* Start the USB device */
					  HAL_PCD_Start(&hpcd_USB_OTG_HS);
					  usb_info.state=USB_MSC_STOP;
				}
				else
				{
					HAL_PCD_Stop(&hpcd_USB_OTG_HS);
				}
			}
			else
			{
				HAL_PCD_Stop(&hpcd_USB_OTG_HS);
				//nothing
			}
			break;
		case USB_MSC_STOP:
			if(USB_DETECT())
			{
				//timer need to run
			}
			else
			{
				HAL_PCD_Stop(&hpcd_USB_OTG_HS);
				SD_info.File_Available=1;
				usb_info.state=USB_MSC_START;
			}
			break;
		case USB_CDC_DONE:

			break;
		case USB_HOST_DONE:

			break;
		case USB_ERR:
			break;
		case USB_HALT:
			break;
		default:
			break;
		}
		tx_thread_sleep(10);
	}
}

UINT MX_USBX_MSC_Device_Init(VOID *memory_ptr)
{
   UINT ret = UX_SUCCESS;
  device_framework_high_speed = (UCHAR *) MSC_device_frameword_high_speed;
  device_framework_hs_length = sizeof(MSC_device_frameword_high_speed);
  /* Get Device Framework Full Speed and get the length */
  device_framework_full_speed =(UCHAR *)MSC_device_frameword_full_speed;
  device_framework_fs_length = sizeof(MSC_device_frameword_full_speed);
  /* Get String Framework and get the length */
  string_framework = USBD_Get_String_Framework(&string_framework_length);

  /* Get Language Id Framework and get the length */
 language_id_framework = USBD_Get_Language_Id_Framework(&language_id_framework_length);
  TX_BYTE_POOL *byte_pool = (TX_BYTE_POOL*)memory_ptr;

  /* USER CODE BEGIN MX_USBX_Device_Init0 */

  /* USER CODE END MX_USBX_Device_Init0 */
  /* Allocate the stack for USBX Memory */
  if (tx_byte_allocate(byte_pool, (VOID **) &DMSC_pointer,
                       USBX_DEVICE_MEMORY_STACK_SIZE, TX_NO_WAIT) != TX_SUCCESS)
  {
    /* USER CODE BEGIN USBX_ALLOCATE_STACK_ERROR */
    return TX_POOL_ERROR;
    /* USER CODE END USBX_ALLOCATE_STACK_ERROR */
  }

  /* Initialize USBX Memory */
  if (ux_system_initialize(DMSC_pointer, USBX_DEVICE_MEMORY_STACK_SIZE, UX_NULL, 0) != UX_SUCCESS)
  {
    /* USER CODE BEGIN USBX_SYSTEM_INITIALIZE_ERROR */
    return UX_ERROR;
    /* USER CODE END USBX_SYSTEM_INITIALIZE_ERROR */
  }

  /* Get Device Framework High Speed and get the length */
  /* Install the device portion of USBX */
  if (ux_device_stack_initialize((UCHAR*)device_framework_high_speed,
                                 device_framework_hs_length,
								 (UCHAR*) device_framework_full_speed,
                                 device_framework_fs_length,
                                 string_framework,
                                 string_framework_length,
                                 language_id_framework,
                                 language_id_framework_length,
                                 UX_NULL) != UX_SUCCESS)
  {
    /* USER CODE BEGIN USBX_DEVICE_INITIALIZE_ERROR */
    return UX_ERROR;
    /* USER CODE END USBX_DEVICE_INITIALIZE_ERROR */
  }

  /* Initialize the storage class parameters for the device */
  storage_parameter.ux_slave_class_storage_instance_activate   = USBD_STORAGE_Activate;
  storage_parameter.ux_slave_class_storage_instance_deactivate = USBD_STORAGE_Deactivate;

  /* Store the number of LUN in this device storage instance */
  storage_parameter.ux_slave_class_storage_parameter_number_lun = STORAGE_NUMBER_LUN;

  /* Initialize the storage class parameters for reading/writing to the Flash Disk */
  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_last_lba = USBD_STORAGE_GetMediaLastLba();

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_block_length = USBD_STORAGE_GetMediaBlocklength();

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_type = 0;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_removable_flag = STORAGE_REMOVABLE_FLAG;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_read_only_flag = STORAGE_READ_ONLY;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_read = USBD_STORAGE_Read;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_write = USBD_STORAGE_Write;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_flush = USBD_STORAGE_Flush;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_status = USBD_STORAGE_Status;

  storage_parameter.ux_slave_class_storage_parameter_lun[0].
    ux_slave_class_storage_media_notification = USBD_STORAGE_Notification;

  /* USER CODE BEGIN STORAGE_PARAMETER */

  /* USER CODE END STORAGE_PARAMETER */

  /* Get storage configuration number */
  storage_configuration_number = USBD_Get_Configuration_Number(CLASS_TYPE_MSC, 0);

  /* Find storage interface number */
  storage_interface_number = USBD_Get_Interface_Number(CLASS_TYPE_MSC, 0);

  /* Initialize the device storage class */
  if (ux_device_stack_class_register(_ux_system_slave_class_storage_name,
                                     ux_device_class_storage_entry,
                                     storage_configuration_number,
                                     storage_interface_number,
                                     &storage_parameter) != UX_SUCCESS)
  {
    /* USER CODE BEGIN USBX_DEVICE_STORAGE_REGISTER_ERROR */
    return UX_ERROR;
    /* USER CODE END USBX_DEVICE_STORAGE_REGISTER_ERROR */
  }

  USBX_APP_Device_Init();

  return ret;
}

UINT MX_USBX_Device_Init(VOID *memory_ptr)
{
	UCHAR *pointer;
	  TX_BYTE_POOL *byte_pool = (TX_BYTE_POOL*)memory_ptr;

	  /* USER CODE BEGIN MX_USBX_Device_Init0 */

	  /* USER CODE END MX_USBX_Device_Init0 */
	  /* Allocate the stack for USBX Memory */
	  if (tx_byte_allocate(byte_pool, (VOID **) &Device_pointer,
	                       USBX_DEVICE_MEMORY_STACK_SIZE, TX_NO_WAIT) != TX_SUCCESS)
	  {
