 __ALIGN_BEGIN static const UCHAR CDC_device_frameword_full_speed[] __ALIGN_END =
 {
     /* Device Descriptor */
     0x12,                               /* bLength */
     UX_DEVICE_DESCRIPTOR_ITEM,          /* bDescriptorType = DEVICE */
     0x00, 0x02,                         /* bcdUSB = 2.00 */
     0x02,                               /* bDeviceClass: CDC */
     0x02,                               /* bDeviceSubClass */     //0x2
     0x00,                               /* bDeviceProtocol */
     0x40,                               /* bMaxPacketSize0 */
     0x83, 0x04,     /* idVendor  = STMicroelectronics */
     (0x40), (0x57),     /* idProduct = Virtual COM Port */
     0x00, 0x02,                         /* bcdDevice */
     0x01,                               /* Index of manufacturer string */
     0x02,                               /* Index of product string */
     0x03,                               /* Index of serial string */
     0x01,                               /* bNumConfigurations */

     /* Configuration Descriptor */
     0x09,                               /* bLength */
     UX_CONFIGURATION_DESCRIPTOR_ITEM,   /* bDescriptorType */   //0x02
     0x4b, 0x00,                           /* wTotalLength */               //0x4b
     0x02,                               /* bNumInterfaces (Comm + Data) */
     0x01,                               /* bConfigurationValue */
     0x00,                               /* iConfiguration */
     0xC0,                               /* bmAttributes: self powered */
     50,                                 /* MaxPower 100 mA */             //0

     /* Communication Class Interface Descriptor */
     0x8,0xb,0x0,0x2,0x2,0x2,0x1,0x0,
     0x09, UX_INTERFACE_DESCRIPTOR_ITEM, /* bLength, bDescriptorType */ //0x9 ,0x4
     0x00,                               /* bInterfaceNumber */
     0x00,                               /* bAlternateSetting */
     0x01,                               /* bNumEndpoints */
     0x02,                               /* bInterfaceClass: CDC */
     0x02,                               /* bInterfaceSubClass: ACM */
     0x01,                               /* bInterfaceProtocol */
     0x00,                               /* iInterface */

     /* Header Functional Descriptor */
     0x05, 0x24, 0x00, 0x10, 0x01,

     /* Call Management Functional Descriptor */
     0x05, 0x24, 0x01, 0x00, 0x01,

     /* ACM Functional Descriptor */
     0x04, 0x24, 0x02, 0x02,

     /* Union Functional Descriptor */
     0x05, 0x24, 0x06, 0x00, 0x01,

     /* Endpoint Descriptor (Notification EP) */
     0x07, UX_ENDPOINT_DESCRIPTOR_ITEM,  //0x7,0x5
     0x82, 0x03, 0x08, 0x00, 0x5,   //0x82,0x3,0x8,0x0,0x5

     /* Data Class Interface Descriptor */
     0x09, UX_INTERFACE_DESCRIPTOR_ITEM,      //09,0x4
     0x01, 0x00, 0x02, 0x0A, 0x00, 0x00, 0x00,

     /* Endpoint Descriptor (Bulk OUT) */
     0x07, UX_ENDPOINT_DESCRIPTOR_ITEM,  //07,0x5
     0x01, 0x02, 0x40, 0x00, 0x00,

     /* Endpoint Descriptor (Bulk IN) */
     0x07, UX_ENDPOINT_DESCRIPTOR_ITEM, //07,0x5
     0x81, 0x02, 0x40, 0x00, 0x00,
 };


