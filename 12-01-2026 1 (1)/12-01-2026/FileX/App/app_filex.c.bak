 int SD_PO(char *name)
 {
 	char temp_int[130];
 	char sd_plumd_read[256]={0,};
 	UINT status;
 	uint8_t value = 0;
 	 int address_plumb = 0;
 	unsigned long bytes_read;
 	//TCHAR   fwpath[16];

 	if ((FX_SUCCESS == fx_file_attributes_read(&mmc_disk, name,&attributes)))
 	{
 		memset(temp_int,0,sizeof(temp_int));
 		if((status = fx_file_open(&mmc_disk, &PO_file, name, FX_OPEN_FOR_READ))==FX_SUCCESS)
 		{
 			status = fx_file_read(&PO_file, &sd_plumd_read[0], 256, &bytes_read); 
 			if(status==FX_SUCCESS)
 			{
 				int k=0;
 				for(int j=0;j<=(bytes_read+1);j++)
 				{
 					if((sd_plumd_read[j]==':') )
 					{
 						address_plumb=convert_to_string(temp_int);
 						if(address_plumb ==1042 || address_plumb == 1040 || address_plumb==IOT_SER_NUM_ADDR || address_plumb == Token_address || address_plumb ==Aws_url_address || address_plumb == DEV_SER_NUM_ADDR)
 						{

 						}
 						else
 						{
 							return 1;
 						}
 						memset(temp_int,0,sizeof(temp_int));
 						k=0;
 						continue;
 					}
 					if((sd_plumd_read[j]==',') && address_plumb != 0)
 					{
 						if(address_plumb==1040 || address_plumb == 1042)
 						{
 							value=convert_to_string(temp_int);
 							EEPROM_Write(address_plumb, 0,(uint8_t*)&value,1);
 							memset(temp_int,0,sizeof(temp_int));
 							address_plumb=0;
 							k=0;
 							continue;
 						}
 						else if(address_plumb==IOT_SER_NUM_ADDR || address_plumb == Token_address || address_plumb == Aws_url_address || address_plumb == DEV_SER_NUM_ADDR)
						{
							if((address_plumb==IOT_SER_NUM_ADDR || address_plumb == Token_address)&& k)
							{
								k=36;
							}
							else if((address_plumb == Aws_url_address) && k)
							{
								k=128;
							}
							else if((address_plumb == DEV_SER_NUM_ADDR) && k)
							{
								k=18;
							}
							if(k)
							{
								EEPROM_Write(address_plumb, 0,(uint8_t*)&temp_int,k);
							}
							memset(temp_int,0,sizeof(temp_int));
							address_plumb=0;
							k=0;
							continue;
						}
 					}

 					if((address_plumb == 0)|| address_plumb==1040 || address_plumb == 1042)
 					{
 						if((sd_plumd_read[j]>=0x30)&&(sd_plumd_read[j]<=0x39))
 						{
 							temp_int[k]=sd_plumd_read[j];
 							k++;
 						}
 					}
 					else if((sd_plumd_read[j] != ' ') && (sd_plumd_read[j] != '\0'))
 					{
 						temp_int[k]=sd_plumd_read[j];
 						k++;
 					}

 				}
 			}
 		}
 		status = fx_file_close(&PO_file);
 		status = fx_file_delete(&mmc_disk,name);
 		status = fx_media_flush(&mmc_disk);
 	}
 	return 0;
 }


 int convert_to_string (char *name)
 {
 	return atoi(name);
 }

 int Settings_Data_sd(void)
 {
 	UINT status;
 	CHAR path[64];
 	UINT attributes;
 	uint8_t week;
 	static uint8_t initial_file=1;
 	static uint8_t  today_date=0;
 	char Filename[16] = {0};
 	//unsigned int  SD_bytes=0;
 	GetFileName(Filename);
 	if(SD_info.state==SD_DONE && (initial_file || (Date.Date != today_date)))
 	{
 		SD_info.state=SD_BUSY;
 		sprintf(path, "%u", Date.Year+2000);
 		status = fx_directory_information_get(&mmc_disk, path, &attributes, &size, &year, &month, &Day, &hour, &minute, &second);
		if (status != FX_SUCCESS) {

			status=fx_directory_create(&mmc_disk,path);
			if(status != FX_SUCCESS){
				status = fx_directory_default_set(&mmc_disk, "\\");
				fx_media_flush(&mmc_disk);
				return status;
			}
		}
		status = fx_directory_default_set(&mmc_disk, path);
		if (status != FX_SUCCESS)
		{
			status = fx_directory_default_set(&mmc_disk, "\\");
			fx_media_flush(&mmc_disk);
			return status;
		}

		sprintf(path,"%s",Month_name[Date.Month-1]);
    	status = fx_directory_information_get(&mmc_disk, path, &attributes, &size, &year, &month, &Day, &hour, &minute, &second);
		if (status != FX_SUCCESS)
		{
			status=fx_directory_create(&mmc_disk,path);
				if(status != FX_SUCCESS){
				status = fx_directory_default_set(&mmc_disk, "\\");
				fx_media_flush(&mmc_disk);
				return status;
			}
		}
		status = fx_directory_default_set(&mmc_disk, path);
		if (status != FX_SUCCESS)
		{
			status = fx_directory_default_set(&mmc_disk, "\\");
			fx_media_flush(&mmc_disk);
			return status;
		}
		week = weekOfMonth(Date.Date, Date.Month, Date.Year+2000);
		status = fx_directory_information_get(&mmc_disk, Week_name[week-1], &attributes, &size, &year, &month, &Day, &hour, &minute, &second);
		if (status != FX_SUCCESS)
		{
			status=fx_directory_create(&mmc_disk,Week_name[week-1]);
			if(status != FX_SUCCESS){
				status = fx_directory_default_set(&mmc_disk, "\\");
				fx_media_flush(&mmc_disk);
				return status;
				}
		}
		status = fx_directory_default_set(&mmc_disk, Week_name[week-1]);
		if (status != FX_SUCCESS)
		{
			status = fx_directory_default_set(&mmc_disk, "\\");
			fx_media_flush(&mmc_disk);
			return status;
		}

//    	    sprintf(path, "%u", Date.Date);
//    	    status = fx_directory_information_get(&mmc_disk, path, &attributes, &size, &year, &month, &Day, &hour, &minute, &second);
//    		if (status != FX_SUCCESS) {
//    	    	status=fx_directory_create(&mmc_disk,path);
//    	    if(status != FX_SUCCESS){
//    	    	return status;
//    	    }
//    		}
//    	    status = fx_directory_default_set(&mmc_disk, path);
//    	    if (status != FX_SUCCESS)
//    	    {
//    	    	return status;
//    	    }
		status= fx_file_open(&mmc_disk,&PO_file,Filename, FX_OPEN_FOR_WRITE);
 		
 		if(status == FX_NOT_FOUND)
 		{
 			Settings_write_data();
 			fx_file_date_time_set(&mmc_disk,Filename,Date.Year,Date.Month,Date.Date,Time.Hours,Time.Minutes,Time.Seconds);
 			if((status = fx_file_create(&mmc_disk, Filename))!=FX_SUCCESS)
 			{
 				 status = fx_file_close(&PO_file);
 				status = fx_directory_default_set(&mmc_disk, "\\");
				fx_media_flush(&mmc_disk);
 				 return 1;
 			}
 			if((status = fx_file_open(&mmc_disk,&PO_file,Filename, FX_OPEN_FOR_WRITE))!= FX_SUCCESS)
 			{
 				status = fx_directory_default_set(&mmc_disk, "\\");
				fx_media_flush(&mmc_disk);
 				return 1;

			}
 			status = fx_file_write(&PO_file,&Data_buffer[0], sizeof(Data_buffer));
 			status = fx_file_close(&PO_file);
// 			if (vp_param_rw_str.mb_cfg.node_id == RS485_MASTER_NODE_ID)
// 			{
// 				if((status = fx_file_open(&mmc_disk, &PO_file, Filename, FX_OPEN_FOR_WRITE))==FX_SUCCESS)
// 				{
// 					status = fx_file_write (&PO_file, &Data_buffer1[0], sizeof(Data_buffer1));
// 				}
// 				status = fx_file_close(&PO_file);
// 			}
 			if(status==FX_SUCCESS)
 			{
 				initial_file=0;
 				today_date=Date.Date;
 			}
 			else
 			{
 				SD_info.state = SD_INIT;
 				 System_Status[ERROR_FLAG_0] |= ERR_SD_CARD_FAILURE;
 			}
 		}
 		else if(status==FX_SUCCESS)
 		{
 			initial_file=0;
 			today_date=Date.Date;
 		}
 	 	status = fx_directory_default_set(&mmc_disk, "\\");
 		fx_media_flush(&mmc_disk);	
 		SD_info.state=SD_DONE;
 	}
 	return 0;
 }

 int weekOfMonth(int day, int month, int year)
 {
     int firstDayWeek = dayOfWeek(1, month, year);  // weekday of 1st day
     int week = ((day + firstDayWeek - 1) / 7) + 1;

     return week;
 }
// Using Zeller’s formula modified for Monday-as-0.
 int dayOfWeek(int d, int m, int y)
 {
     if (m < 3) {
         m += 12;
         y -= 1;
     }

     int K = y % 100;
     int J = y / 100;

     int h = (d + (13 * (m + 1)) / 5 + K + K/4 + J/4 + 5*J) % 7;

     // Zeller: 0=Saturday, 1=Sunday, 2=Monday...
     int dow = (h + 5) % 7; // Convert so Monday = 0

     return dow;
 }

