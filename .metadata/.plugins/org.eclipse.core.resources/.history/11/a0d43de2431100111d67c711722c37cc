HAL_StatusTypeDef Flash_Write(uint8_t *data, uint32_t length, uint32_t start_address)
{
    HAL_StatusTypeDef status = HAL_OK;
    uint32_t address = start_address;

    // Unlock Flash for programming
    status = HAL_FLASH_Unlock();
    if(status != HAL_OK) return status;

    // Use a static aligned buffer for quadword programming
    static uint64_t quadBuf[2]; // 16 bytes, 64-bit aligned

    for (uint32_t i = 0; i < length; i += 16)
    {
        uint32_t chunkSize = (length - i >= 16) ? 16 : (length - i);

        // Fill buffer with 0xFF (default erased value)
        quadBuf[0] = 0xFFFFFFFFFFFFFFFF;
        quadBuf[1] = 0xFFFFFFFFFFFFFFFF;

        // Copy actual data into the quadword buffer
        memcpy(quadBuf, &data[i], chunkSize);

        // Program flash: address must be 16-byte aligned
        status = HAL_FLASH_Program(FLASH_TYPEPROGRAM_QUADWORD, address + i, (uint32_t)quadBuf);
        if(status != HAL_OK)
        {
            HAL_FLASH_Lock();
            return status;
        }
    }


    // Lock Flash after programming
    HAL_FLASH_Lock();
    return status;



}


void File_validation(void)
{
    UINT status;
    ULONG bytes_read;
    uint8_t buffer[BLOCK_SIZE];
    uint16_t StartCrc = 0x1D0F;

    // Try to open file from FileX
    status = fx_file_open(&mmc_disk, &fx_file, APPLICATION_FILE_NAME, FX_OPEN_FOR_READ);

    if (status == FX_SUCCESS)
    {
    	status = fx_file_seek(&fx_file, 0);
        do
        {
        	  memset(buffer, 0x00, BLOCK_SIZE);
            // Read file data

            status = fx_file_read(&fx_file, buffer, BLOCK_SIZE, &bytes_read);

            if ((status == FX_SUCCESS) && (bytes_read > 0))
            {
                StartCrc = crc16_ccitt_bin(buffer, bytes_read, StartCrc);
            }
            else
            {
            	bytes_read=0;
                if (StartCrc == 0)
                {
                    Update.update_firmware = 1;
                    EEPROM_Write(Firmware_update_flag, 0,(uint8_t*)&Update.update_firmware ,1);
//                    fx_media_flush(&mmc_disk);
                    fx_file_close(&fx_file);
                    emmc_info.state = EMMC_INIT;
                }
                else
                {
                    Update.update_firmware = 0;

                    // Delete invalid file
                    fx_media_flush(&mmc_disk);
                    fx_file_close(&fx_file);

                    status =  fx_file_delete(&mmc_disk, APPLICATION_FILE_NAME);
//                    tx_timer_activate(&usb_first_timeout_timer);
   				 Set_delay(BOOT_DELAY, DLY_CDC_START, &BOOT_info.app_flag);
   				 creating_file("CTRS_CFC.bin");
                    //emmc_info.state = EMMC_ERROR;

                }
