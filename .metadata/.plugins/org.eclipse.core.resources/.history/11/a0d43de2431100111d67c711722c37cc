        } while ((status == FX_SUCCESS) && (bytes_read > 0));


    }
    else
    {
        printf("No application file found.\r\n");
        Update.update_firmware = 0;
        mythread_flag =1;
        emmc_info.state = EMMC_ERROR;
    }
