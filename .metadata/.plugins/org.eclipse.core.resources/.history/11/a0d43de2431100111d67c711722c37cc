void disable_irqs_and_systick(void)
{
    __disable_irq();
    SysTick->CTRL = 0;
    SysTick->LOAD = 0;
    SysTick->VAL  = 0;

    uint32_t n = (MCU_IRQS + 31) / 32;
    for (uint32_t i = 0; i < n; i++) {
        NVIC->ICER[i] = 0xFFFFFFFF;
        NVIC->ICPR[i] = 0xFFFFFFFF;
    }

    __DSB();
    __ISB();
}
