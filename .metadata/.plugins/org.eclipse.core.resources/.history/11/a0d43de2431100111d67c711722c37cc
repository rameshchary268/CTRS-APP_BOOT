void boot_proc(void)
{
    static uint8_t read_buffer[600];
    ULONG bytes_read;
    uint8_t flash_verify_buf[512];   // temporary verify buffer



    switch (emmc_info.state)
    {
        case EMMC_INIT:
            printf("Initializing eMMC...\n\r");
//            media_open();   // Mount eMMC
            emmc_info.state = EMMC_FILE_OPEN;
            break;

        case EMMC_FILE_OPEN:
        	EEPROM_Read(Firmware_update_flag, 0,(uint8_t*)&Update.update_firmware ,1);
            if(Update.update_firmware)
            {
            	 emmc_info.status = fx_file_open(&mmc_disk, &fx_file, APPLICATION_FILE_NAME, FX_OPEN_FOR_READ);

				if (emmc_info.status == FX_SUCCESS)
				{
					printf("File found.\n\r");
					emmc_info.file_size = fx_file.fx_file_current_file_size;
					emmc_info.total_written = 0;
					emmc_info.flash_write_addr = APPLICATION_START_ADDR;
					Update.update_firmware = 1;
					emmc_info.state = EMMC_ERASE;
//					emmc_info.status = fx_file_close(&fx_file);
				}
				else if (emmc_info.status == FX_NOT_FOUND)
				{
					emmc_info.status = fx_file_close(&fx_file);
					 printf("No update file found. Checking flash CRC...\n\r");
					 Update.update_firmware=0;
					  EEPROM_Write(Firmware_update_flag, 0,(uint8_t*)&Update.update_firmware ,1);
					  //emmc_info.state = EMMC_FILE_VALIDATE;

				}
				else
				{
					emmc_info.status = fx_file_close(&fx_file);
					printf("File open error! Status: %u\n\r", emmc_info.status);
					emmc_info.state = EMMC_ERROR;

				}
            }
            else
            {
            	emmc_info.state = EMMC_FILE_VALIDATE;
            }

            break;
        case EMMC_FILE_VALIDATE:
        {
        	if(BOOT_info.app_flag)
			{
				 RunFlashCheck();
			}
        	break;
        }
        case EMMC_ERASE:
            printf("Erasing application flash...\n\r");
            if (Erase_Flash_SingleBank() == HAL_OK)
            {
                printf("Erase complete.\n\r");
                // Seek to start (optional if already at 0)
                emmc_info.status = fx_file_seek(&fx_file, emmc_info.total_written);
                emmc_info.state = EMMC_WRITE;
            }
            else
            {
                printf("Erase failed!\n\r");
                emmc_info.state = EMMC_ERROR;

//            	tx_thread_suspend(&ux_cdc_write_thread);
            }
            break;

        case EMMC_WRITE:
//        	 emmc_info.status = fx_file_open(&mmc_disk, &fx_file, APPLICATION_FILE_NAME, FX_OPEN_FOR_READ);
        	flash_flag=1;
        	    if (emmc_info.total_written < emmc_info.file_size)
        	    {

        	        ULONG bytes_to_read = (emmc_info.file_size - emmc_info.total_written >= 512) ?
        	                                  512 : (emmc_info.file_size - emmc_info.total_written);

        	        // 1️⃣ Read 512 bytes from eMMC file
        	        status = fx_file_read(&fx_file, read_buffer, bytes_to_read, &bytes_read);

        	        if (status != FX_SUCCESS)
        	        {
//        	            printf("Read failed at offset %lu\n\r", emmc_info.total_written);
        	            emmc_info.state = EMMC_ERROR;
        	            break;
        	        }

        	        // 2️⃣ Write that chunk to Flash
        	        if (Flash_Write(read_buffer, bytes_read, emmc_info.flash_write_addr) != HAL_OK)
        	        {
//        	            printf("Flash write failed at 0x%08lX\n\r", emmc_info.flash_write_addr);
        	            emmc_info.state = EMMC_ERROR;
        	            break;
        	        }
        	        emmc_info.flash_write_addr += bytes_read;
        	        emmc_info.total_written += bytes_read;
        	    }
        	    else
        	    {
        	       // printf("\n\rFirmware update complete and verified!\n\r");
        	        fx_file_close(&fx_file);
        	        tx_thread_resume(&ux_cdc_write_thread);
        	        emmc_info.state = EMMC_CLEANUP;
        	    }

        	    break;

        case EMMC_VERIFY:
            printf("Verifying flashed firmware...\n\r");

               ULONG bytes_read;
               ULONG offset = 0;
               uint32_t flash_addr = APPLICATION_START_ADDR;
               UINT status;

               // Reopen firmware file for reading
               status = fx_file_open(&mmc_disk, &fx_file, APPLICATION_FILE_NAME, FX_OPEN_FOR_READ);
               if (status != FX_SUCCESS)
               {
                   printf("File open failed during verify! Status: %u\n\r", status);
                   emmc_info.state = EMMC_ERROR;
                   break;
               }

               while (offset < emmc_info.file_size)
               {
                   uint32_t bytes_to_read = ((emmc_info.file_size - offset) >= VERIFY_CHUNK_SIZE) ?
                                            VERIFY_CHUNK_SIZE : (emmc_info.file_size - offset);

                   // Read data from eMMC file
                   status = fx_file_read(&fx_file, emmc_buffer, bytes_to_read, &bytes_read);
                   if (status != FX_SUCCESS)
                   {
//                       printf("Read failed during verify at offset %lu\n\r", offset);
                       emmc_info.state = EMMC_ERROR;
                       fx_file_close(&fx_file);
                       break;
                   }

                   // Read data from Flash
                   memcpy(flash_buffer, (uint8_t *)flash_addr, bytes_to_read);

                   // Compare buffers
                   if (memcmp(emmc_buffer, flash_buffer, bytes_to_read) != 0)
                   {
//                       printf("Verification failed at flash addr 0x%08lX\n\r", flash_addr);
                       emmc_info.state = EMMC_ERROR;
                       fx_file_close(&fx_file);
                       break;
                   }

                   // Move pointers forward
                   flash_addr += bytes_to_read;
                   offset += bytes_read;
               }

               if (emmc_info.state != EMMC_ERROR)
               {
                   printf("Firmware verification successful!\n\r");
                   emmc_info.state = EMMC_CLEANUP;
               }

               fx_file_close(&fx_file);
               break;

        case EMMC_CLEANUP:
        	flash_flag=0;
            printf("Cleaning up...\n\r");
            fx_file_close(&fx_file);
            fx_file_delete(&mmc_disk, "CTRS_CFC.bin");
            printf("Deleted firmware file.\n\r");
            emmc_info.state = EMMC_JUMP;
            break;


        case EMMC_JUMP:
            printf("Jumping to application...\n\r");
            jump_flag = 1;
            emmc_info.state = EMMC_DONE;
            break;

        case EMMC_DONE:
            // Finished
        	if(Update.update_firmware)
        	{
        		CrcCheckStatus=0;
    	        RunFlashCheck();

//        		goto_application1(APPLICATION_START_ADDR);
        	}


            break;

        case EMMC_ERROR:
            printf("Error occurred during update.\n\r");
            fx_file_close(&fx_file);
            emmc_info.state = EMMC_DONE;
            break;

        default:
            emmc_info.state = EMMC_INIT;
            break;
    }
}




void write_flash_to_emmc(void) {

	UINT status = FX_SUCCESS;

	// ✅ Copy flash_read_buffer into data buffer before writing to file
	memcpy(data, flash_read_buffer, READ_SIZE);

	status = fx_file_create(&mmc_disk, "Flash_APP.bin");
	/* Check the create status.  */
	if (status != FX_SUCCESS) {
		/* Check for an already created status. This is expected on the
		 second pass of this loop!  */
		if (status != FX_ALREADY_CREATED) {
			/* Create error, call error handler.  */
			Error_Handler();
		}
	}

	status = fx_file_open(&mmc_disk, &fx_file, "Flash_APP.bin",
			FX_OPEN_FOR_WRITE);
	/* Check the file open status.  */
	if (status != FX_SUCCESS) {
		/* Error opening file, call error handler.  */
		Error_Handler();
	}
	/* Seek to the beginning of the test file.  */
	status = fx_file_seek(&fx_file, 0);
	/* Check the file seek status.  */
	if (status != FX_SUCCESS) {
		/* Error performing file seek, call error handler.  */
		Error_Handler();
	}

	/* Write a string to the test file.  */
	status = fx_file_write(&fx_file, data, sizeof(data));
	/* Check the file write status.  */
	if (status != FX_SUCCESS) {
		/* Error writing to a file, call error handler.  */
		Error_Handler();
	}
	/* Close the test file.  */
	status = fx_file_close(&fx_file);
	/* Check the file close status.  */
	if (status != FX_SUCCESS) {
		/* Error closing the file, call error handler.  */
		Error_Handler();
	}
}

